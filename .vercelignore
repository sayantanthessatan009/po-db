# --------------------------
# Node / npm
# --------------------------
node_modules/
package-lock.json
pnpm-lock.yaml
yarn.lock
.npm
.eslintcache

# --------------------------
# Build outputs (keep only what Vercel needs)
# --------------------------
# Vercel will serve the `dist` folder, but we don’t want to
# upload intermediate build artifacts that are already covered
# by the build step.
dist/
.cache/
.tmp/
.temp/
.coverage/
.nyc_output/

# --------------------------
# Environment & secrets
# --------------------------
.env
.env.*
! .env.example   # keep the example file if you want to show require

# --------------------------
# Logs & runtime files
# --------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids
*.pid
*.seed
*.pid.lock

# --------------------------
# Editor / IDE
# --------------------------
# VS Code
.vscode/
# JetBrains
.idea/
# Sublime
*.sublime-workspace
*.sublime-project
# Emacs
*~
# Vim
*.swp
*.swo
*.swn

# --------------------------
# OS / system files
# --------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --------------------------
# Miscellaneous
# --------------------------
# If you have any test coverage reports or similar artifacts
coverage/
lcov-info
*.lcov

# Optional: ignore large binary assets that aren’t used in the build
# (uncomment if you have such files)
# assets/**/*.psd
# assets/**/*.ai
# assets/**/*.sketch